<mujoco model="scene_push_cube">
    <include file="so101_new_calib_camera.xml" />

    <visual>
        <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0" />
        <rgba haze="0.15 0.25 0.35 1" />
        <global azimuth="160" elevation="-20" />
    </visual>

    <asset>
        <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512"
            height="3072" />
        <texture type="2d" name="groundplane" builtin="checker" mark="edge" rgb1="0.2 0.3 0.4"
            rgb2="0.1 0.2 0.3"
            markrgb="0.8 0.8 0.8" width="300" height="300" />
        <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5"
            reflectance="0.2" />
    </asset>

    <worldbody>
        <light pos="0 0 3.5" dir="0 0 -1" directional="true" />
        <geom name="floor" size="0 0 0.05" pos="0 0 0" type="plane" material="groundplane" />

        <!-- Pedestal to mount the robot base (base sits at z=0.15 in python script) -->
        <geom name="pedestal" type="box" size="0.075 0.075 0.075" pos="0 0 0.075" rgba="0.3 0.3 0.3 1" />

        <!-- Green Target Area: 8 cm x 8 cm square (half-size 0.04m) -->
        <geom name="target_green" type="box" size="0.04 0.04 0.0001" pos="0.2 0.1 0.0001" rgba="0 1 0 0.5" contype="0" conaffinity="0" />

        <!-- Blue Target Area: 8 cm x 8 cm square (half-size 0.04m) -->
        <geom name="target_blue" type="box" size="0.04 0.04 0.0001" pos="0.2 -0.1 0.0001" rgba="0 0 1 0.5" contype="0" conaffinity="0" />

        <!-- Red Cube: 3 cm x 3 cm x 3 cm (half-size 0.015m) -->
        <body name="cube" pos="0.18 0.0 0.015">
            <freejoint name="cube_joint" />
            <geom name="cube_geom" type="box" size="0.015 0.015 0.015" rgba="1 0 0 1" mass="0.05" friction="1 0.005 0.0001" />
            <!-- Visual site to easily track its position -->
            <site name="cube_site" pos="0 0 0" size="0.005" rgba="0 0 0 0" />
        </body>
    </worldbody>
</mujoco>
